CurrentGraph == 
    CASE NumNodes = 1   -> G1
      [] NumNodes = 2   -> G1a
      [] NumNodes = 4   -> G3
      [] NumNodes = 5   -> G2
      [] NumNodes = 9   -> G4
      [] NumNodes = 50  -> G7
      [] NumNodes = 101 -> GDH
      [] OTHER          -> G7

Init ==
    /\ state \in CurrentGraph.initials

Next ==
    /\ state \in CurrentGraph.states
    /\ state' \in CurrentGraph.actions[state]

Spec ==
    /\ Init
    /\ [][Next]_state
    /\ WF_state(Next)

THEOREM Spec => []TRUE

